{
    "version": "2.0",
    "description": "Defines context rules for the Main Thread to inject into 0-state subagents upon spawning.",
    "agent_role_context": {
        "sonders": {
            "required_docs": [
                "00-Project-Memory.md",
                "blueprint/planning/roadmap.md",
                "blueprint/design/architecture_overview.md"
            ]
        },
        "negator": {
            "required_docs": [
                "00-Project-Memory.md",
                "blueprint/design/architecture_overview.md",
                "blueprint/design/design_principles.md"
            ]
        },
        "execution_architect": {
            "required_docs": [
                "00-Project-Memory.md",
                "runtime/tracking/active_sprint.md"
            ]
        },
        "worker": {
            "required_docs": [
                "blueprint/engineering/dev_workflow.md"
            ]
        },
        "sdet": {
            "required_docs": [
                "blueprint/engineering/testing_strategy.md"
            ]
        },
        "auditor": {
            "required_docs": [
                "blueprint/design/architecture_overview.md",
                "blueprint/design/design_principles.md"
            ]
        }
    },
    "path_based_rules": [
        {
            "project_path": "src/frontend/components/*",
            "inject_docs": [
                "blueprint/design/architecture_overview.md"
            ]
        },
        {
            "project_path": "src/backend/api/*",
            "inject_docs": [
                "blueprint/design/api_mapping.md"
            ]
        }
    ]
}